# Local demo: parse backend/src/test-status.html instead of a live Tomcat server
USE_TEST_FILE=true

# Backend port (Vite proxy forwards /api to this port)
PORT=3001

# Production Tomcat discovery (required when USE_TEST_FILE is not true)
# TOMCAT_STATUS_URL=https://tomcat.example.com/manager/status
# TOMCAT_USER=admin
# TOMCAT_PASS=secret
# TOMCAT_SCHEME=https
# TOMCAT_HOST=tomcat.example.com
# TOMCAT_PORT=8443
